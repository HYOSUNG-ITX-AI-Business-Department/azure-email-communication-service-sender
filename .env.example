# SMTP Configuration
SMTP_HOST=smtp.azurecomm.net
SMTP_PORT=587
SMTP_USERNAME=your-entra-smtp-username
SMTP_PASSWORD=your-smtp-password

# Allowed MailFrom addresses (comma-separated)
ALLOWED_MAILFROM=sender@yourdomain.com,noreply@yourdomain.com

# Allowed custom headers (comma-separated)
ALLOWED_HEADERS=X-Request-ID,X-Correlation-ID

# Valkey Configuration (Redis-compatible)
REDIS_URL=redis://localhost:6379/0

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://emailuser:emailpass@localhost:5432/emails

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
